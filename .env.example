# Copy this file to .env and fill in your own values.
# .env is git-ignored — never commit real secrets.

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
PORT=3000
NODE_ENV=development

# ---------------------------------------------------------------------------
# PostgreSQL (matches docker-compose.yml defaults — change if you run your own)
# ---------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nicheradar
POSTGRES_USER=nicheradar
POSTGRES_PASSWORD=nicheradar
# Full connection string (used by the app; keep in sync with the vars above)
DATABASE_URL=postgresql://nicheradar:nicheradar@localhost:5432/nicheradar

# ---------------------------------------------------------------------------
# Etsy Open API v3 (OPTIONAL)
# The app runs fine without these — Etsy-based saturation features are
# simply disabled if they're missing.
# Get credentials at: https://www.etsy.com/developers
# ---------------------------------------------------------------------------
ETSY_API_KEY=
ETSY_API_SECRET=
